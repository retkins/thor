{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch Wire Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test_wire.o",
            "args": [],         // command line args                
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",       
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "test-wire"
        }
    ]
}