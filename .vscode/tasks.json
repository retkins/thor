{
    "tasks": [
        {
            "label": "test-wire",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-O0", 
                "-march=native",
                "-g",
                "-I${workspaceFolder}/src", // header search path, needed?
                "${workspaceFolder}/src/biotsavart.c",
                "${workspaceFolder}/src/octree.c",
                "${workspaceFolder}/src/utils.c",
                "${workspaceFolder}/tests/test_wire.c",
                "-o",
                "${workspaceFolder}/build/test_wire.o", 
                "-lm"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}